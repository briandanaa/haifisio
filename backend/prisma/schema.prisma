// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  phone     String?
  createdAt DateTime @default(now())

  patient   Patient?
  therapist Therapist?
  doctor    Doctor?
}

enum Role {
  ADMIN
  PATIENT
  THERAPIST
  DOCTOR
}

model Patient {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  dateOfBirth DateTime?
  gender      String?
  address     String?

  user     User      @relation(fields: [userId], references: [id])
  bookings Booking[]
}

model Therapist {
  id                 Int     @id @default(autoincrement())
  userId             Int     @unique
  licenseNumber      String
  specialization     String?
  experienceYears    Int?
  clinicAddress      String?
  statusVerification Boolean @default(false)

  user     User      @relation(fields: [userId], references: [id])
  bookings Booking[]
}

model Doctor {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  sipNumber    String
  hospitalName String?

  user User @relation(fields: [userId], references: [id])
}

model Booking {
  id          Int @id @default(autoincrement())
  patientId   Int
  therapistId Int

  patient   Patient   @relation(fields: [patientId], references: [id])
  therapist Therapist @relation(fields: [therapistId], references: [id])

  bookingDate DateTime
  location    String
  status      BookingStatus @default(PENDING)

  sessions TherapySession[] // ✅ sudah benar
}

model TherapySession {
  id            Int      @id @default(autoincrement())
  bookingId     Int
  sessionNumber Int // 🔥 TAMBAHKAN INI
  createdAt     DateTime @default(now())

  // RELATION
  report  TherapyReport[] // 🔥 ini penting
  booking Booking         @relation(fields: [bookingId], references: [id])
}

model TherapyReport {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  therapistId Int
  painScale   Int
  notes       String
  createdAt   DateTime @default(now())

  // RELATION
  session TherapySession @relation(fields: [sessionId], references: [id])
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}
